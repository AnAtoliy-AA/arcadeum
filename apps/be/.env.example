# Backend Environment Example (.env)

# --- Core Application ---
NODE_ENV=development
BE_PORT=4000

# --- Database ---
# MongoDB connection string (required)
MONGODB_URI=

# --- Sentry (optional) ---
SENTRY_DSN=

# --- OAuth (Google) ---
OAUTH_ISSUER=https://accounts.google.com
OAUTH_WEB_CLIENT_ID=
OAUTH_WEB_CLIENT_SECRET=
OAUTH_WEB_REDIRECT_URI=http://localhost:3000/auth/callback
OAUTH_WEB_ALLOWED_ORIGINS=http://localhost:3000

# --- Auth (JWT) ---
AUTH_JWT_SECRET=

# --- Payments (PayPal, optional) ---
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_BRAND_NAME=
PAYPAL_RETURN_URL=http://localhost:3000/payment/success
PAYPAL_CANCEL_URL=http://localhost:3000/payment/cancel

# --- Socket Encryption ---
SOCKET_ENCRYPTION_ENABLED=true
SOCKET_ENCRYPTION_KEY=
ALLOWED_ORIGINS=

# --- Economy settings (runtime-tunable) ---
# All values below are env-var fallbacks only. Admins can override any of them
# at runtime via the /admin/economy page without restarting the server.
# The override is stored in MongoDB and takes effect after the cache TTL.
# Removing a DB override restores the env-var value (or the code default).

# TTL (in seconds) for the in-process economy settings cache.
# Set to 0 to disable caching entirely (every getNumber() hits MongoDB).
# Default: 60. Changes require a server restart to take effect.
ECONOMY_CACHE_TTL_SECONDS=60

# --- Wallet / Rewards ---
# Number of coins awarded to each winner when a game session completes.
# Must be a positive integer. Defaults to 50 if unset or invalid.
# Overridable at runtime via /admin/economy (key: game_win_coin_reward).
GAME_WIN_COIN_REWARD=50

# --- Gem Conversion ---
# Exchange rate for converting gems to coins (gems × rate = coins).
# Must be a positive integer. Defaults to 100 if unset or invalid.
# Overridable at runtime via /admin/economy (key: gem_to_coin_rate).
GEM_TO_COIN_RATE=100

# --- Wallet / Referrals ---
# Flat coin reward credited to a referrer on every successful trackReferral.
# Positive integer; 0 disables the payout. Default 50.
# Overridable at runtime via /admin/economy (key: referral_reward_coins_per).
REFERRAL_REWARD_COINS_PER=50
# One-time coin bonus when crossing each existing tier (3/5/10 invites).
# Positive integer; 0 disables that tier's coin bonus. Defaults 100/200/500.
# Overridable at runtime via /admin/economy (keys: referral_tier_{1,2,3}_bonus_coins).
REFERRAL_TIER_1_BONUS_COINS=100
REFERRAL_TIER_2_BONUS_COINS=200
REFERRAL_TIER_3_BONUS_COINS=500

# --- Support / Contact Form ---
# Recipient inbox for contact-form submissions (POST /support/contact).
# Any channel below that's left blank will be skipped — the BE marks that
# channel as `unconfigured` on the persisted document and the other still
# fires, so the form won't break in dev.
SUPPORT_EMAIL=arcadeum.care@gmail.com

# Discord webhook URL for instant triage pings. Create per channel via
# Server → Channel → Integrations → Webhooks → New Webhook → Copy URL.
# Use separate webhooks for dev vs prod so noise doesn't ping live.
DISCORD_SUPPORT_WEBHOOK_URL=

# Gmail SMTP (nodemailer). SMTP_PASS is a 16-char Google App Password —
# the Gmail account must have 2-Step Verification enabled.
# https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=arcadeum.care@gmail.com
SMTP_PASS=
SMTP_FROM=Arcadeum Support <arcadeum.care@gmail.com>

# Shared secret the Next.js server action sends to the BE so OriginGuard
# accepts server-to-server submissions (server actions have no Origin
# header). The same value must be set on apps/web's server env. Generate
# with: openssl rand -hex 32
# If left blank in DEVELOPMENT, OriginGuard allows server-action calls
# without it (dev convenience). In PRODUCTION this MUST be set, otherwise
# the BE rejects all contact-form posts via the server action.
SUPPORT_INTERNAL_TOKEN=

# E2E test mode. When set to "true", the support module short-circuits:
# MailerService and DiscordNotifierService skip real delivery (return
# 'unconfigured'), and SupportThrottlerGuard skips the per-IP rate limit.
# Apps/web's playwright.config.ts sets this for its spawned BE webServer.
# Leave UNSET in dev/prod — the bypass would let everyone past the rate
# limit and silently drop real submissions.
# E2E=true

# --- Solana Configuration ---
# RPC endpoint for Solana mainnet (or devnet for testing).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Platform wallet secret key as a JSON array of 64 numbers.
# Generate with: solana-keygen new --outfile keypair.json
# Then read the file contents and paste as the value.
SOLANA_PRIVATE_KEY=[64,secret,key,numbers,here]
# SPL token mint address for the ARCADEUM token on Solana.
# Replace after launching the token on Pump.fun.
ARCADEUM_MINT_ADDRESS=your_token_mint_address_here

# --- Web Push (PWA notifications, ARC-740) ---
# Generate with: pnpm --filter be exec ts-node scripts/generate-vapid-keys.ts
# If left empty the notifications module still works for inbox + socket,
# but no OS push is sent.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:support@arcadeum.com

