# Backend API base URL (required)
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000

# WebSocket base URL (optional, defaults to API base URL)
NEXT_PUBLIC_WS_BASE_URL=http://localhost:4000

# Socket Encryption (AES-256-GCM)
NEXT_PUBLIC_SOCKET_ENCRYPTION_ENABLED=true

# Auth Configuration
NEXT_PUBLIC_AUTH_WEB_REDIRECT_URL=http://localhost:3000/auth/callback
NEXT_PUBLIC_AUTH_ISSUER=https://accounts.google.com
NEXT_PUBLIC_AUTH_WEB_CLIENT_ID=

# Social Media
NEXT_PUBLIC_SOCIAL_INSTAGRAM=
NEXT_PUBLIC_SOCIAL_FACEBOOK=
NEXT_PUBLIC_SOCIAL_YOUTUBE=
NEXT_PUBLIC_SOCIAL_TIKTOK=
NEXT_PUBLIC_SOCIAL_LINKEDIN=
NEXT_PUBLIC_SOCIAL_LINKEDIN_DEVELOPER=
NEXT_PUBLIC_SOCIAL_THREADS=
NEXT_PUBLIC_SOCIAL_X=
NEXT_PUBLIC_SOCIAL_DISCORD=

# Presentation
NEXT_PUBLIC_PRESENTATION_VIDEO_ID=

# Support & Legal
NEXT_PUBLIC_PRIVACY_EMAIL=
NEXT_PUBLIC_SUPPORT_EMAIL=
NEXT_PUBLIC_ID_CODE=
NEXT_PUBLIC_LEGAL_NAME=
NEXT_PUBLIC_SUPPORT_URL=

# Server-only — must match SUPPORT_INTERNAL_TOKEN on the BE. The contact
# form's server action sends this on its POST to /support/contact so the
# BE's OriginGuard accepts the server-to-server fetch (no Origin header).
# Generate with: openssl rand -hex 32
SUPPORT_INTERNAL_TOKEN=

# SEO
NEXT_PUBLIC_WEB_SEO_TITLE=
NEXT_PUBLIC_WEB_SEO_DESCRIPTION=
NEXT_PUBLIC_SITE_URL=https://arcadeum.games

# Search-engine site verification. Paste the value from each console's
# meta-tag verification method — Next.js wires it into the right
# <meta> tag automatically.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_YANDEX_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_YAHOO_SITE_VERIFICATION=

# Downloads
NEXT_PUBLIC_DOWNLOAD_IOS=
NEXT_PUBLIC_DOWNLOAD_ANDROID=

# Development
WEB_PORT=3000
NEXT_PUBLIC_DEV_WAKE_THRESHOLD_MS=10000

# Web Push public key (ARC-740). Must match BE VAPID_PUBLIC_KEY.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# Solana — ARCADEUM SPL token mint address (used in wallet token-info section).
ARCADEUM_MINT_ADDRESS=your_token_mint_address_here

# GeckoTerminal pool address for ARC/USDC price chart (found on geckoterminal.com)
NEXT_PUBLIC_CDN_URL=https://pub-your-cloudflare-cdn.r2.dev

NEXT_PUBLIC_ARC_POOL_ADDRESS=your_pool_address_here
