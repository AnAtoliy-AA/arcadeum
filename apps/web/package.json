{
  "name": "web",
  "version": "1.15.10",
  "private": true,
  "browserslist": [
    "chrome >= 87",
    "firefox >= 78",
    "safari >= 14",
    "edge >= 88"
  ],
  "scripts": {
    "dev": "rm -rf .next && next dev -p $(node ../../scripts/resolve-env-port.js .env.local WEB_PORT 3000)",
    "dev:next": "rm -rf .next && next dev -p $(node ../../scripts/resolve-env-port.js .env.local WEB_PORT 3000)",
    "build": "next build",
    "start": "next start -p $(node ../../scripts/resolve-env-port.js .env.local WEB_PORT 3000)",
    "lint": "eslint",
    "type-check": "tsc --noEmit",
    "storybook": "node scripts/patch-next-config.js && storybook dev -p 6006",
    "build-storybook": "node scripts/patch-next-config.js && storybook build",
    "test:e2e": "playwright test",
    "test:e2e:local": "rm -rf .next && NEXT_PUBLIC_E2E=true E2E_PROD=true pnpm run build && E2E_PROD=true NEXT_PUBLIC_E2E=true playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "i18n:audit": "vitest run src/shared/i18n/messages/completeness.test.ts",
    "i18n:audit:update": "vitest run src/shared/i18n/messages/completeness.test.ts -u"
  },
  "dependencies": {
    "@arcadeum/ui": "workspace:*",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@ducanh2912/next-pwa": "^10.2.9",
    "@tamagui/avatar": "2.0.0-rc.23",
    "@tamagui/config": "2.0.0-rc.23",
    "@tamagui/next-plugin": "2.0.0-rc.23",
    "@tamagui/shorthands": "2.0.0-rc.23",
    "next": "16.1.7",
    "pixi-filters": "^6",
    "pixi.js": "^8",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native-web": "^0.21.0",
    "socket.io-client": "^4.8.1",
    "tamagui": "2.0.0-rc.23",
    "zustand": "^5.0.10"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.0",
    "@next/bundle-analyzer": "^16.2.4",
    "@playwright/test": "^1.58.0",
    "@storybook/addon-a11y": "^10.2.1",
    "@storybook/addon-docs": "^10.2.1",
    "@storybook/addon-onboarding": "^10.2.1",
    "@storybook/nextjs-vite": "10.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/browser-playwright": "^4.0.16",
    "@vitest/coverage-v8": "^4.0.16",
    "babel-loader": "^10.0.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "16.1.0",
    "eslint-plugin-storybook": "^10.2.1",
    "jsdom": "^27.4.0",
    "mongodb-memory-server": "^11.1.0",
    "playwright": "^1.58.0",
    "storybook": "^10.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.0",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.16"
  }
}
